<div class="kotak-profile">
    <h1>Profile</h1>
    <% if (locals.profile) { %>
        <form method="POST" action="/profile/<%= profile.id %>">
            <label>Nama:</label>
            <input
                type="text"
                name="nama"
                value="<%= profile.name %>"
            >

            <label>Nomor HP:</label>
            <input
                type="text"
                name="nohp"
                value="<%= profile.nomor_hp %>"
            >

            <label>Password Baru:</label>
            <input
                type="password"
                name="password"
            >

            <button type="submit">
                Simpan
            </button>
    </form>
    <% } else {%>
        <h1>Data Error</h1>
    <% } %>
</div>

<%- include('partials/footer') %>
