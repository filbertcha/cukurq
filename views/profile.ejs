          <a href="/logout">Logout</a>
        </div>
      </div>
    </div>
  <% } else if (profile.role === "admin") {%>
    <div class="navbar">
        <div class="nav">
        <div class="nav1">
            <h2>CukurQ</h2>
        </div>
        <div class="nav2">
            <a href="/admin">Beranda</a>
