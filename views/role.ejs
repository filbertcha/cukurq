<div class="kotak-role">
    <h1>Kelola Role User</h1>

    <table border="1">
        <tr>
            <th>Nama</th>
            <th>No HP</th>
            <th>Role</th>
            <th>Aksi</th>
        </tr>

        <% users.forEach(user => { %>
            <tr>
                <td>
                    <%= user.name %>
                </td>
                <td>
                    <%= user.nomor_hp %>
                </td>
                <td>
                    <%= user.role %>
                </td>
                <td>
                    <form
                    action="/role/<%= user.id %>"
                    method="POST"
                    >
                        <select name="role">
                            <option value="customer">
                                customer
                            </option>
                            <option value="admin">
                                admin
                            </option>
                            <option value="super admin">
                                super admin
                            </option>
                        </select>
                        <button type="submit">
                            Simpan
                        </button>
                    </form>
                </td>
            </tr>
        <% }) %>

    </table>
</div>

